# --- Own Postgres (never shared with mac-auth or any other app) ---
# Password: letters + digits only (openssl rand -hex 24)
POSTGRES_USER=crm
POSTGRES_PASSWORD=changeme
POSTGRES_DB=crm

# Assembled from the above when running via docker-compose. For local dev,
# point at your local Postgres.
DATABASE_URL=postgres://crm:changeme@localhost:5432/crm

# --- MAC Suite auth (verify.ts reads AUTH_URL for JWKS) ---
AUTH_URL=https://auth.monashcoding.com
JWT_ISSUER=https://auth.monashcoding.com
JWT_AUDIENCE=mac-suite

# --- App ---
PORT=3000

# --- Backups ---
BACKUP_KEEP_DAYS=14

# --- Gmail reply detection (optional) ---
# The web server does NOT need these; only the poller (npm run gmail:sync) and the
# one-time auth script (npm run gmail:auth) do. Left blank, the poller runs idle.
# One OAuth client (Internal app on the monashcoding.com Workspace) is shared by all
# mailboxes; get these from Google Cloud Console → APIs & Services → Credentials.
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx
# Days of inbox to backfill on a mailbox's first-ever sync.
GMAIL_SEED_WINDOW_DAYS=3
# One refresh token per shared inbox, minted by `npm run gmail:auth` signed in AS that
# mailbox. Add GMAIL_RECRUITMENT_REFRESH_TOKEN / GMAIL_EVENTS_REFRESH_TOKEN as you
# onboard those inboxes (and uncomment them in src/gmail/mailboxes.ts).
GMAIL_SPONSORSHIP_REFRESH_TOKEN=
