# --- Own Postgres (never shared with mac-auth or any other app) ---
# Password: letters + digits only (openssl rand -hex 24)
POSTGRES_USER=crm
POSTGRES_PASSWORD=changeme
POSTGRES_DB=crm

# Assembled from the above when running via docker-compose. For local dev,
# point at your local Postgres.
DATABASE_URL=postgres://crm:changeme@localhost:5432/crm

# --- MAC Suite auth (verify.ts reads AUTH_URL for JWKS) ---
AUTH_URL=https://auth.monashcoding.com
JWT_ISSUER=https://auth.monashcoding.com
JWT_AUDIENCE=mac-suite

# --- App ---
PORT=3000

# --- Backups ---
BACKUP_KEEP_DAYS=14
